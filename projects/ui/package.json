{
  "name": "@ardium-ui/ui",
  "version": "1.0.2",
  "peerDependencies": {
    "@angular/common": ">=18.0.0",
    "@angular/core": ">=18.0.0",
    "@angular/cdk": ">=18.0.0"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "first-last": "^1.1.1",
    "more-rounding": "^4.2.2",
    "resolve-object-path": "^1.1.0",
    "@ardium-ui/devkit": "^1.3.10",
    "simple-bool": "^3.0.1",
    "color": "^4.2.3",
    "string-similarity": "^4.0.4"
  },
  "devDependencies": {
    "@types/color": "^3.0.6",
    "@types/string-similarity": "^4.0.2"
  },
  "scripts": {
    "build-sass": "sass ./src/themes:../../dist/ui/prebuilt-themes/"
  },
  "exports": {
    "./prebuilt-themes/*": {

{
  "name": "ardium-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "ngg-um": "ng g m --project=ui",
    "ngg-uc": "ng g c --project=ui --change-detection=OnPush --export --view-encapsulation=None",
    "ngg-pm": "ng g m --project=playground",
    "ngg-pc": "ng g c --type=page --project=playground"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^15.2.5",
    "@angular/cdk": "^15.2.5",
    "@angular/compiler": "^15.2.5",
    "@angular/core": "^15.2.5",
    "@angular/forms": "^15.2.5",
    "@angular/platform-browser": "^15.2.5",
    "@angular/platform-browser-dynamic": "^15.2.5",
    "@angular/router": "^15.2.5",
    "@types/color": "^3.0.3",
    "@types/string-similarity": "^4.0.0",
    "color": "^4.2.3",
    "first-last": "^1.1.1",
    "key-display-names": "^1.1.1",
    "more-rounding": "^4.0.1",
    "resolve-object-path": "^1.1.0",
    "rxjs": "~7.5.0",
    "simple-bool": "^3.0.1",
    "string-similarity": "^4.0.4",
    "tslib": "^2.3.0",
    "zone.js": "~0.11.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^15.2.4",

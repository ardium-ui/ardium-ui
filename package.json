{
  "name": "ardium-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "ngg-um": "ng g m --project=ui",
    "ngg-uc": "ng g c --project=ui --change-detection=OnPush --export --view-encapsulation=None",
    "ngg-pm": "ng g m --project=playground",
    "ngg-pc": "ng g c --type=page --project=playground",
    "publish-devkit": "rmdir /s /Q dist & ng build --project=devkit && cd dist/devkit && npm publish --access public && cd ../../",
    "publish-ui": "rmdir /s /Q dist & cd projects/ui && ng build --configuration=production && npm run build-sass && cd ../../ && node copy-scss.js && cd dist/ui && npm publish --access=public && cd ../../",
    "version-ui": "cd projects/ui && npm version",
    "prettier": "prettier --write ."
  },
  "dependencies": {
    "@angular/animations": "^17.0.7",
    "@angular/cdk": "^17.0.4",
    "@angular/compiler": "^17.0.7",
    "@angular/core": "^17.0.7",
    "@angular/forms": "^17.0.7",
    "@angular/platform-browser": "^17.0.7",
    "@angular/platform-browser-dynamic": "^17.0.7",
    "@angular/router": "^17.0.7",
    "@ardium-ui/devkit": "^1.3.6",
    "@ardium-ui/ui": "^1.0.2",
    "color": "^4.2.3",
    "first-last": "^1.1.1",
    "key-display-names": "^1.2.0",
    "more-rounding": "^4.2.1",
    "resolve-object-path": "^1.1.0",
    "rxjs": "~7.5.0",
    "simple-bool": "^3.0.1",
    "string-similarity": "^4.0.4",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.7",
    "@angular/cli": "^17.0.7",
    "@angular/compiler-cli": "^17.0.7",
    "@types/color": "^3.0.3",
    "@types/jasmine": "~3.10.0",
    "@types/node": "^12.11.1",
    "@types/string-similarity": "^4.0.0",
    "jasmine-core": "~4.0.0",
    "karma": "~6.3.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.1.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "ng-packagr": "^17.0.2",
    "typescript": "~5.2.2"
  }
}

{
  "name": "ardium-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port=4240 --project=playground",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "ngg-um": "ng g m --project=ui",
    "ngg-uc": "ng g c --project=ui --change-detection=OnPush --export --view-encapsulation=None",
    "ngg-pm": "ng g m --project=playground",
    "ngg-pc": "ng g c --type=page --project=playground",
    "release": "node ./scripts/release.js",
    "prettier": "prettier --write .",
    "lint": "ng lint"
  },
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "dependencies": {
    "@angular/animations": "^21.0.3",
    "@angular/cdk": "^21.0.2",
    "@angular/common": "^21.0.3",
    "@angular/compiler": "^21.0.3",
    "@angular/core": "^21.0.3",
    "@angular/forms": "^21.0.3",
    "@angular/platform-browser": "^21.0.3",
    "@angular/platform-browser-dynamic": "^21.0.3",
    "@angular/router": "^21.0.3",
    "@ardium-ui/devkit": "^7.7.1",
    "first-last": "^1.1.1",
    "key-display-names": "^2.0.0",
    "more-rounding": "^4.2.2",
    "resolve-object-path": "^2.0.0",
    "rxjs": "~7.8.0",
    "simple-bool": "^3.0.1",
    "take-chance": "^4.3.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^21.0.1",
    "@angular/cli": "^21.0.1",
    "@angular/compiler-cli": "^21.0.3",
    "@types/node": "^20.14.2",
    "angular-eslint": "18.0.1",
    "ansis": "^4.1.0",
    "eslint": "^9.3.0",
    "inquirer": "^12.7.0",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.0.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "sass": "^1.91.0",
    "typescript-eslint": "8.0.0-alpha.20"
  }
}

{
  "name": "ardium-ui",
  "version": "3.3.0-alpha.9",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port=4240 --project=playground",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "ngg-um": "ng g m --project=ui",
    "ngg-uc": "ng g c --project=ui --change-detection=OnPush --export --view-encapsulation=None",
    "ngg-pm": "ng g m --project=playground",
    "ngg-pc": "ng g c --type=page --project=playground",
    "release": "node ./scripts/release.js",
    "prettier": "prettier --write .",
    "lint": "ng lint"
  },
  "dependencies": {
    "@angular/animations": "^19.2.15",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.15",
    "@angular/compiler": "^19.2.15",
    "@angular/core": "^19.2.15",
    "@angular/forms": "^19.2.15",
    "@angular/platform-browser": "^19.2.15",
    "@angular/platform-browser-dynamic": "^19.2.15",
    "@angular/router": "^19.2.15",
    "@ardium-ui/devkit": "8.0.2-alpha.2",
    "first-last": "^1.1.1",
    "key-display-names": "^2.0.0",
    "lodash": "^4.17.23",
    "more-rounding": "^4.2.2",
    "resolve-object-path": "^2.0.0",
    "rxjs": "~7.8.0",
    "simple-bool": "^3.0.1",
    "take-chance": "^4.3.2",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.16",
    "@angular/cli": "^19.2.16",
    "@angular/compiler-cli": "^19.2.15",
    "@types/jasmine": "~5.1.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.14.2",
    "angular-eslint": "18.0.1",
    "ansis": "^4.1.0",
    "eslint": "^9.3.0",
    "inquirer": "^12.7.0",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^19.2.2",
    "sass": "^1.91.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.0.0-alpha.20"
  }
}
